{
  "name": "docrot-cli",
  "version": "0.2.1",
  "description": "Find the lies in your docs — verifies every code example, import, link and config in your markdown against the code that actually ships.",
  "keywords": [
    "documentation",
    "docs",
    "readme",
    "markdown",
    "code-examples",
    "lint",
    "ci",
    "developer-experience"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getdocrot/docrot.git"
  },
  "bugs": "https://github.com/getdocrot/docrot/issues",
  "homepage": "https://github.com/getdocrot/docrot#readme",
  "type": "module",
  "bin": {
    "docrot": "dist/cli.js",
    "docrot-mcp": "dist/mcp.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "action.yml"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "docrot": {
    "exclude": [
      "test/fixtures/**"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.2",
    "github-slugger": "^2.0.0",
    "ignore": "^5.3.1",
    "mdast-util-from-markdown": "^2.0.1",
    "picocolors": "^1.0.1",
    "typescript": "^5.5.0",
    "yaml": "^2.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.14.0",
    "npm-high-impact": "^1.13.0",
    "tsup": "^8.1.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0"
  }
}
